# =====================================================
# SkyMessage shared environment
# Copy to .env at repo root, and to apps/*/  as needed.
# =====================================================

# --- Supabase (shared) ---
# Public, safe to ship to web/desktop clients
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Server-only. NEVER expose to web/desktop renderer bundles.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SECRET_SERVICE_ROLE_KEY

# --- API server (apps/server) ---
SERVER_PORT=8787
SERVER_HOST=0.0.0.0
SERVER_BASE_URL=http://localhost:8787
ALLOWED_ORIGINS=http://localhost:3000,app://skymessage

# --- Web (apps/web) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
# Set after you upload the installer somewhere (GitHub Releases, Dropbox direct link, etc.)
NEXT_PUBLIC_DOWNLOAD_WIN_URL=

# --- Desktop (apps/desktop) ---
# Production builds bake these in via electron-vite env (see deploy.ps1)
DESKTOP_API_BASE_URL=http://localhost:8787
DESKTOP_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
DESKTOP_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
DESKTOP_AUTO_LAUNCH=true

# --- Auth providers (web) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Optional: rate-limit backing store ---
# Leave empty to use in-memory store (single-process only)
REDIS_URL=
